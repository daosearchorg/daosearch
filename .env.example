# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=qidian
DB_PASSWORD=your_database_password
DB_NAME=qidian
DB_SSLMODE=disable

# Redis Configuration
REDIS_URL=redis://localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-20b:nitro
OPENAI_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# Scraper Configuration
CRAWLER_REQUEST_TIMEOUT=60

# Worker Concurrency Configuration
SCRAPER_WORKER_CONCURRENCY=1
TRANSLATION_WORKER_CONCURRENCY=1
MAINTENANCE_WORKER_CONCURRENCY=1

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URL=http://localhost:8080/auth/discord/callback

# Session Configuration
AUTH_SECRET=your_session_secret_base64

# Cloudflare R2 Storage Configuration
STORAGE_ACCESS_KEY_ID=your_r2_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_r2_secret_access_key
STORAGE_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
STORAGE_BUCKET_NAME=your_bucket_name
STORAGE_PUBLIC_URL=https://your_bucket_public_url

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_BOT_CLIENT_ID=your_discord_bot_client_id
DISCORD_GUILD_ID=your_discord_guild_id
API_BASE_URL=http://localhost:8080/api/v1
