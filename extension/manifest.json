{
  "manifest_version": 3,
  "name": "DaoSearch Reader",
  "version": "0.1.0",
  "description": "Translate Chinese web novels with DaoSearch — entity glossary, progress tracking, and community features.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "externally_connectable": {
    "matches": ["http://localhost:8080/*", "https://daosearch.io/*", "https://www.daosearch.io/*"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "Readability.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
